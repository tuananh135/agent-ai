# Copiez en .env.local puis renseignez les valeurs.

# --- LLM : renseignez UNE des deux clés ---
# Option A — OpenRouter (un compte, plusieurs fournisseurs), utilisé en priorité.
OPENROUTER_API_KEY=sk-or-v1-...
# Option B — Anthropic direct.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (obligatoire) : Project Settings → API ---
SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...
